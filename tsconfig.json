{
  "compilerOptions": {
    /* Replace the old baseUrl/paths with this */
    "paths": {
      "@/*": ["./src/*"]
    },
    // Add this to silence the deprecation warning if it persists
    "ignoreDeprecations": "5.0", 
    
    /* Rest of your config... */
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}